DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jespinoza_barberia?schema=public"

# Solo necesaria en producción con un proveedor "pooled" (ej. Supabase +
# pgbouncer): una conexión directa (sin pooler) que usan las migraciones.
# En local, déjala sin definir — cae de vuelta a DATABASE_URL.
# DIRECT_URL="postgresql://user:password@host:5432/postgres"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
JWT_COOKIE_MAX_AGE_SECONDS="604800"
BUSINESS_TIMEZONE="America/Lima"

SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me"
